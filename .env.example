# Copy to .env and fill in. Never commit .env (it's in .gitignore).
#
# ─────────────────────────────────────────────────────────────────────────────
# Tailscale
# ─────────────────────────────────────────────────────────────────────────────
# Auth key from https://login.tailscale.com/admin/settings/keys
# Generate with: Reusable=No, Ephemeral=No, Tags=tag:hermes (or equivalent)
TS_AUTHKEY=tskey-auth-REPLACE_ME

# Hostname this node will register on the tailnet (no dots)
TS_HOSTNAME=hermes-cloud

# Your tailnet domain (the part AFTER the hostname in <name>.<tailnet>.ts.net)
# Example: if your tailnet is `tail-xxxxx.ts.net`, set:
#   TS_TAILNET=tail-xxxxx.ts.net
# Caddy will serve at https://${TS_HOSTNAME}.${TS_TAILNET}
TS_TAILNET=your-tailnet-name.ts.net

# ─────────────────────────────────────────────────────────────────────────────
# Matrix bot
# ─────────────────────────────────────────────────────────────────────────────
MATRIX_BOT_USER=@hermes-bot:hermes.local
MATRIX_BOT_PASSWORD=REPLACE_ME

# Room IDs (find with: curl http://localhost:8000/rooms after first start)
MATRIX_ADMIN_ROOM=
APARTMENT_UPDATE_ROOM=

# ─────────────────────────────────────────────────────────────────────────────
# Apartment search job
# ─────────────────────────────────────────────────────────────────────────────
APARTMENT_BUDGET_SOLO=3000
APARTMENT_BUDGET_SHARED=2500
APARTMENT_DAILY_CRON_HOUR=8     # UTC hour to run the daily update

# ─────────────────────────────────────────────────────────────────────────────
# LLM provider (see app/llm.py for the supported envs)
# ─────────────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Model selection if applicable
# LLM_MODEL=claude-sonnet-4-6
